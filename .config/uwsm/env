# ~/.config/uwsm/env
# Universal environment variables for all Wayland sessions
# UWSM documentation: https://github.com/Vladimir-csp/uwsm

#============= XDG BASE DIRECTORIES ==============#
# XDG Base Directory Specification
# Reference: https://specifications.freedesktop.org/basedir-spec/latest/
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache" 
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

#============= APPLICATION DIRECTORIES ===========#
# Move application data to XDG-compliant locations
export DOCKER_CONFIG="$XDG_CONFIG_HOME/docker"
export CARGO_HOME="$XDG_DATA_HOME/cargo"
export RUSTUP_HOME="$XDG_DATA_HOME/rustup"
export GOPATH="$XDG_DATA_HOME/go"
export GNUPGHOME="$XDG_DATA_HOME/gnupg"
export NPM_CONFIG_USERCONFIG="$XDG_CONFIG_HOME/npm/npmrc"
export LESSHISTFILE="$XDG_STATE_HOME/less/history"
export GTK2_RC_FILES="$XDG_CONFIG_HOME/gtk-2.0/gtkrc"

#============= WAYLAND ENVIRONMENT ==============#
# Backend Configuration - Prioritize Wayland
export GDK_BACKEND="wayland,x11,*"
export CLUTTER_BACKEND="wayland"
export SDL_VIDEODRIVER="wayland"

# QT/KDE Configuration for Wayland
export QT_QPA_PLATFORM="wayland;xcb"  # Fallback to X11 if needed
export QT_QPA_PLATFORMTHEME="qt6ct"
export QT_WAYLAND_DISABLE_WINDOWDECORATION="1"
export QT_AUTO_SCREEN_SCALE_FACTOR="1"
export QT_STYLE_OVERRIDE=""  # Let qt6ct handle it
export KDE_SESSION_VERSION="5"  # Helps with KDE app theming
export KDE_FULL_SESSION="true"

# GTK Configuration for Wayland
# GTK_THEME removed - use gtk settings.ini and Material You colors instead
export GDK_SCALE="1"

# Cursor Configuration  
export XCURSOR_SIZE="18"

# Mozilla/Firefox Wayland optimizations
export MOZ_ENABLE_WAYLAND="1"
export MOZ_WAYLAND_USE_VAAPI="1"
# Security: Keep sandbox enabled (removed MOZ_DISABLE_CONTENT_SANDBOX)

# Electron apps Wayland support
export OZONE_PLATFORM="wayland"
export ELECTRON_OZONE_PLATFORM_HINT="wayland"

#============= DESKTOP PORTAL ENVIRONMENT ==============#
# Ensure proper desktop environment detection for portal services
export XDG_CURRENT_DESKTOP="Hyprland"
export XDG_SESSION_TYPE="wayland"

# Help applications identify the correct portal backend
export XDG_DESKTOP_PORTAL_FORCE_BACKEND="hyprland"

# Ensure D-Bus session communication is properly configured
export DBUS_SESSION_BUS_ADDRESS="unix:path=$XDG_RUNTIME_DIR/bus"

#============= EDITOR AND TOOLS =================#
export EDITOR="/usr/bin/helix"
export VISUAL="$EDITOR"
export PAGER="less"

#============= DEVELOPMENT TOOLS ================#
export JQ_COLORS="0;90:0;37:0;37:0;37:0;32:1;37:1;37:1;34"

# Python
export PYTHONSTARTUP="$HOME/python/pythonrc"

# .NET Configuration
export DOTNET_CLI_HOME="$XDG_DATA_HOME/dotnet"
export NUGET_PACKAGES="$XDG_CACHE_HOME/NuGetPackages"

#============= BROWSER AND LINK HANDLING ===============#
# Optional: Set fallback browser if xdg-mime detection fails
# Uncomment and adjust if needed:
# export BROWSER="firefox"

# Help Java applications (like JetBrains Toolbox) with link handling
export DESKTOP_SESSION="Hyprland"
export XDG_SESSION_DESKTOP="Hyprland"

#============== APP SPECIFIC ====================#
source ~/.config/uwsm/env-moonlight
