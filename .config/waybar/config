{
    "layer": "bottom",
    "position": "top",
    "height": 50,
    "spacing": 2,
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": [
        "custom/notification",
        "clock",
        "custom/pacman",
        "tray"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "group/expand",
        "network",
        "wireplumber",
        "custom/capslock",
        "custom/power"
    ],
    "custom/notification": {
        "tooltip": true,
        "format": "{icon}",
        "format-icons": {
            "notification": "َ°‚ڑ",
            "none": "َ°‚œ",
            "dnd-notification": "َ°‚›",
            "dnd-none": "َ°ھ‘",
            "inhibited-notification": "َ°‚ ",
            "inhibited-none": "َ°ھ‘",
            "dnd-inhibited-notification": "َ°‚ ",
            "dnd-inhibited-none": "َ°ھ‘"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "clock": {
        "format": "{:%a, %d %b  %H:%M}",
        "format-alt": "{:%A, %B %d, %Y  %I:%M %p}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "format": {
                "months": "<span color='#fabd2f'><b>{}</b></span>",
                "days": "<span color='#ebdbb2'><b>{}</b></span>",
                "weeks": "<span color='#d79921'><b>W{}</b></span>",
                "weekdays": "<span color='#d79921'><b>{}</b></span>",
                "today": "<span color='#fb4934' background='#3c3836'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "custom/pacman": {
        "format": "َ°…¢ {}",
        "interval": 900,
        "exec": "checkupdates | wc -l",
        "exec-if": "exit 0",
        "on-click": "uwsm app -- foot sh -c 'paru -Syu; echo \"\\nUpdate complete. Press Enter to exit...\"; read'; pkill -SIGRTMIN+8 waybar",
        "signal": 8,
        "tooltip-format": "System updates available: {}\nClick to update with paru"
    },
    "tray": {
        "icon-size": 16,
        "icon-theme": "Gruvbox-Material-Dark",
        "spacing": 8,
        "show-passive-items": false,
        "reverse-direction": true
    },
    "hyprland/workspaces": {
        "show-special": true,
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "active": "ï’ھ",
            "urgent": "َ°µڑ",
            "default": "ï„‘",
            "special": "َ°“ژ"
        },
        "persistent-workspaces": {
            "*": [
                1,
                2,
                3,
                4,
                5
            ]
        },
        "on-click": "activate",
        "sort-by-number": true
    },
    "group/expand": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500,
            "transition-to-left": true,
            "click-to-reveal": true
        },
        "modules": [
            "custom/expand",
            "cpu",
            "memory",
            "temperature",
            "custom/endpoint"
        ]
    },
    "custom/expand": {
        "format": "ï„„",
        "tooltip": true,
        "tooltip-format": "Click to expand"
    },
    "cpu": {
        "format": "َ°»  {usage}%",
        "interval": 2,
        "states": {
            "warning": 70,
            "critical": 90
        },
        "tooltip": true,
        "tooltip-format": "CPU Usage: {usage}%\nFrequency: {avg_frequency} GHz\nLoad: {load}",
        "on-click": "uwsm app -- foot htop"
    },
    "memory": {
        "format": " {percentage}%",
        "interval": 2,
        "states": {
            "warning": 70,
            "critical": 85
        },
        "tooltip": true,
        "tooltip-format": "Memory: {used:0.1f}G / {total:0.1f}G ({percentage}%)\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "on-click": "uwsm app -- foot htop"
    },
    "temperature": {
        "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
        "input-filename": "temp1_input",
        "warning-threshold": 75,
        "critical-threshold": 90,
        "format": "{icon} {temperatureC}آ°C",
        "format-icons": [
            "َ°ˆ¸",
            "َ±ƒƒ",
            "َ°”ڈ",
            "َ±ƒ‚",
            "َ°¸پ"
        ],
        "interval": 5,
        "tooltip": true,
        "on-click": "uwsm app -- foot htop"
    },
    "custom/endpoint": {
        "format": "|",
        "tooltip": false
    },
    "network": {
        "format-wifi": "َ°¤¨ {signalStrength}%",
        "format-ethernet": "َ°ˆ€",
        "format-disconnected": "َ°¤­",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "tooltip-format": "Network: {ifname}\nIP: {ipaddr}\nGateway: {gwaddr}\nStrength: {signalStrength}%\nFreq: {frequency} MHz\nSpeed: {bandwidthUpBytes} â¬† {bandwidthDownBytes} â¬‡",
        "tooltip-format-ethernet": "Ethernet: {ifname}\nIP: {ipaddr}\nSpeed: {bandwidthUpBytes} â¬† {bandwidthDownBytes} â¬‡",
        "tooltip-format-disconnected": "Network: Disconnected",
        "on-click-right": "uwsm app -- nm-connection-editor",
        "interval": 3
    },
    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں Muted",
        "format-icons": {
            "default": [
                "َ°–€",
                "َ°•¾",
                "َ°•¾",
                "َ°•¾"
            ],
            "headphone": [
                "َ°‹‹",
                "َ°‹‹",
                "َ°‹‹",
                "َ°‹‹"
            ],
            "headset": [
                "َ°‹ژ",
                "َ°‹ژ",
                "َ°‹ژ",
                "َ°‹ژ"
            ],
            "speaker": [
                "َ°–€",
                "َ°•¾",
                "َ°•¾",
                "َ°•¾"
            ],
            "hdmi": [
                "َ°،پ",
                "َ°،پ",
                "َ°،پ",
                "َ°،پ"
            ]
        },
        "tooltip": true,
        "tooltip-format": "Audio: {desc}\nVolume: {volume}%\nNode: {node_name}",
        "on-click": "uwsm app -- pwvucontrol",
        "scroll-step": 2.0,
        "max-volume": 150,
        "interval": 1,
        "exec-if": "pgrep wireplumber",
        "restart-interval": 3,
        "target": "@DEFAULT_AUDIO_SINK@"
    },
    "custom/capslock": {
        "exec": "~/.config/waybar/scripts/capslock.sh",
        "interval": "once",
        "return-type": "json",
        "signal": 1
    },
    "custom/power": {
        "format": "َ°گ¥",
        "tooltip": true,
        "tooltip-format": "Power Options",
        "on-click": "pgrep -x wlogout || uwsm app -- wlogout -p layer-shell"
    }
}
