{
    "layer": "bottom",
    "position": "top",
    "height": 50,
    "spacing": 2,
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": [
        "custom/notification",
        "clock",
        "custom/pacman",
        "tray"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "group/expand",
        "bluetooth",
        "network",
        "battery",
        "wireplumber",
        "custom/capslock",
        "custom/power"
    ],

    // LEFT MODULE
    "custom/notification": {
        "tooltip": true,
        "format": "{icon}",
        "format-icons": {
            "notification": "ґ░ВЪ",
            "none": "ґ░ВЬ",
            "dnd-notification": "ґ░ВЫ",
            "dnd-none": "ґ░кС",
            "inhibited-notification": "ґ░Ва",
            "inhibited-none": "ґ░кС",
            "dnd-inhibited-notification": "ґ░Ва",
            "dnd-inhibited-none": "ґ░кС"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "clock": {
        "format": "{:%a, %d %b  %H:%M}",
        "format-alt": "{:%A, %B %d, %Y  %I:%M %p}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "format": {
                "months": "<span color='#fabd2f'><b>{}</b></span>",
                "days": "<span color='#ebdbb2'><b>{}</b></span>",
                "weeks": "<span color='#d79921'><b>W{}</b></span>",
                "weekdays": "<span color='#d79921'><b>{}</b></span>",
                "today": "<span color='#fb4934' background='#3c3836'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "custom/pacman": {
        "format": "ґ░Ев {}",
        "interval": 900,
        "exec": "checkupdates | wc -l",
        "exec-if": "exit 0",
        "on-click": "uwsm app -- foot sh -c 'paru -Syu; echo \"\\nUpdate complete. Press Enter to exit...\"; read'; pkill -SIGRTMIN+8 waybar",
        "signal": 8,
        "tooltip-format": "System updates available: {}\nClick to update with paru"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 8,
        "show-passive-items": false,
        "reverse-direction": true
    },

    // CENTER MODULE
    "hyprland/workspaces": {
        "show-special": true,
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "active": "яТк",
            "urgent": "ґ░╡Ъ",
            "default": "яДС",
            "special": "ґ░УО"
        },
        "persistent-workspaces": {
            "*": [ 1,2,3,4,5 ]
        },
        "on-click": "activate",
        "sort-by-number": true
    },

//    "hyprland/window": {
//        "format": "{}",
//        "max-length": 50,
//        "separate-outputs": true,
//        "rewrite": {
//            "(.*) тАФ Mozilla Firefox": "ґ░И╣ $1",
//            "(.*) - foot": "юЮХ $1", 
//            "(.*) - Helix": "ґ▒й╝ $1",
//            "(.*) - Signal": "ґ░Нй $1",
//            "": "ґ░гЗ"
//        }
//    },

    //---------------RIGHT MODULES---------------
    // EXPAND/GROUP MODULES
    "group/expand": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500,
            "transition-to-left": true,
            "click-to-reveal": true
        },
        "modules": [
            "custom/expand",
//            "custom/colorpicker",
            "cpu",
            "memory", 
            "temperature",
            "custom/endpoint"
        ]
    },
    "custom/expand": {
        "format": "яДД",
        "tooltip": true,
        "tooltip-format": "Click to expand"
    },
//    "custom/colorpicker": {
//        "format": "юнЬ",
//        "return-type": "json",
//        "interval": "once",
//        "exec": "~/.config/waybar/scripts/colorpicker.sh -j",
//        "on-click": "~/.config/waybar/scripts/colorpicker.sh",
//        "signal": 1,
//        "tooltip": true
//    },
    "cpu": {
        "format": "ґ░╗а {usage}%",
        "interval": 2,
        "states": {
            "warning": 70,
            "critical": 90
        },
        "tooltip": true,
        "tooltip-format": "CPU Usage: {usage}%\nFrequency: {avg_frequency} GHz\nLoad: {load}",
        "on-click": "uwsm app -- foot htop"
    },
    "memory": {
        "format": "ю┐Е {percentage}%",
        "interval": 2,
        "states": {
            "warning": 70,
            "critical": 85
        },
        "tooltip": true,
        "tooltip-format": "Memory: {used:0.1f}G / {total:0.1f}G ({percentage}%)\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "on-click": "uwsm app -- foot htop"
    },
    "temperature": {
        "warning-threshold": 65,
        "critical-threshold": 75,
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": ["ґ░И╕", "ґ▒ГГ", "ґ░ФП", "ґ▒ГВ", "ґ░╕Б"],
        "interval": 5,
        "tooltip": true,
        "on-click": "uwsm app -- foot htop"
    },
    "custom/endpoint": {
        "format": "|",
        "tooltip": false
    },

    // ALWAYS VISIBLE MODULES
    "bluetooth": {
        "format": "ґ░Вп",
        "format-disabled": "ґ░В▓",
        "format-connected": "ґ░В▒ {num_connections}",
        "format-connected-battery": "ґ░В▒ {device_alias} {device_battery_percentage}%",
        "tooltip-format": "Bluetooth: {status}\n{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "Bluetooth: {status}\n{controller_alias}\t{controller_address}\n\nConnected:\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "тАв {device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "тАв {device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "uwsm app -- blueman-manager",
        "on-click-right": "rfkill toggle bluetooth"
    },
    "network": {
        "format-wifi": "ґ░ди {signalStrength}%",
        "format-ethernet": "ґ░ИА",
        "format-disconnected": "ґ░дн",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "tooltip-format": "Network: {ifname}\nIP: {ipaddr}\nGateway: {gwaddr}\nStrength: {signalStrength}%\nFreq: {frequency} MHz\nSpeed: {bandwidthUpBytes} тмЖ {bandwidthDownBytes} тмЗ",
        "tooltip-format-ethernet": "Ethernet: {ifname}\nIP: {ipaddr}\nSpeed: {bandwidthUpBytes} тмЖ {bandwidthDownBytes} тмЗ",
        "tooltip-format-disconnected": "Network: Disconnected",
        "on-click-right": "uwsm app -- nm-connection-editor",
        "interval": 3
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "ґ░ВД {capacity}%",
        "format-plugged": "ґ░ВД {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["ґ░Б║", "ґ░Б╗", "ґ░Б╝", "ґ░Б╜", "ґ░Б╛", "ґ░Б┐", "ґ░ВА", "ґ░ВБ", "ґ░ВВ", "ґ░Б╣"],
        "tooltip-format": "Battery: {capacity}%\nTime: {time}\nPower: {power}W\nCycles: {cycles}\nHealth: {health}%",
        "max-length": 25,
    },
    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "ґ░ЭЯ Muted",
        "format-bluetooth": "ґ░Вп {volume}%",
        "format-bluetooth-muted": "ґ░В▓ Muted", 
        "format-source": "ґ░Нм {volume}%",
        "format-source-muted": "ґ░Нн Muted",
        "format-icons": {
            "default": ["ґ░ЦА", "ґ░Х╛", "ґ░Х╛", "ґ░Х╛"],
            "headphone": ["ґ░ЛЛ", "ґ░ЛЛ", "ґ░ЛЛ", "ґ░ЛЛ"],
            "headphones": ["ґ░ЛЛ", "ґ░ЛЛ", "ґ░ЛЛ", "ґ░ЛЛ"],
            "headset": ["ґ░ЛО", "ґ░ЛО", "ґ░ЛО", "ґ░ЛО"],
            "speaker": ["ґ░ЦА", "ґ░Х╛", "ґ░Х╛", "ґ░Х╛"],
            "hdmi": ["ґ░бБ", "ґ░бБ", "ґ░бБ", "ґ░бБ"],
            "bluetooth": ["ґ░Вп", "ґ░Вп", "ґ░Вп", "ґ░Вп"],
            "a2dp-sink": ["ґ░Вп", "ґ░Вп", "ґ░Вп", "ґ░Вп"],
        },
        "tooltip": true,
        "tolltip-format": "Audio: {desc}\nVolume: {volume}%\nNode: {node_name}",
        "on-click": "uwsm app -- pwvucontrol",
        "scroll-step": 2.0,
        "max-volume": 150,
        "interval": 1,
        "exec-if": "pgrep wireplumber",
        "restart-interval": 3,
        "nospacing": true,
        "states": {
            "muted": 0,
            "low": 20,
            "medium": 50,
            "high": 80,
            "critical": 100
        },
        "node-blacklist": [],
        "device-blacklist": [],
        "show-source": false,
        "ignored-sinks": ["Family 17h/19h HD Audio Controller Analog Stereo"],
        "target": "@DEFAULT_AUDIO_SINK@"
    },
    "custom/capslock": {
        "exec": "~/.config/waybar/scripts/capslock.sh",
        "interval": "once",
        "return-type": "json",
        "signal": 1
    },
    "custom/power": {
        "format": "ґ░Ре",
        "tooltip": true,
        "tooltip-format": "Power Options",
        "on-click": "uwsm app -- wlogout -p layer-shell",
        "on-click-right": "uwsm app -- foot ~/.config/hypr/scripts/power.sh"
    }
}

